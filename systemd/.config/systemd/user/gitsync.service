[Unit]
Description=Daily Git Auto-Sync
Wants=network-online.target
After=network-online.target

[Service]
Type=oneshot
# Ensure 1000 matches UID (check with 'id -u')
Environment=DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/1000/bus
Environment=DISPLAY=:0
ExecStart=/usr/bin/bash %h/.local/bin/gitsync.sh

# If the script fails (e.g., no internet), retry every 5 minutes
Restart=on-failure
RestartSec=300

[Install]
WantedBy=default.target
